<Window x:Class="DynamicIslandPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="Dynamic Island PC" 
        Width="115" Height="60"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style x:Key="ControlButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid ClipToBounds="False">
        <Border x:Name="IslandBorder" 
                CornerRadius="35"
                ClipToBounds="False">
            <Border.Background>
                <SolidColorBrush Color="#000000" Opacity="0.7"/>
            </Border.Background>
        
        <Grid>
            <!-- Минимальный режим - иконка + гифка -->
            <Grid x:Name="MinimalMode" Visibility="Visible">
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid Grid.Column="0">
                        <Ellipse Width="50" Height="50" Fill="Gray"/>
                        <Image x:Name="AlbumArtMinimal" Width="40" Height="40" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5">
                            <Image.Clip>
                                <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                            </Image.Clip>
                            <Image.RenderTransform>
                                <RotateTransform x:Name="AlbumArtMinimalRotation" Angle="0"/>
                            </Image.RenderTransform>
                        </Image>
                    </Grid>
                    
                    <Grid Grid.Column="1" x:Name="GifMinimalContainer" Visibility="Collapsed" Margin="5,0,0,0" Width="50" Height="50">
                        <Ellipse Width="50" Height="50" Fill="Gray"/>
                        <Image x:Name="GifMinimal" Width="40" Height="40" Stretch="UniformToFill" gif:ImageBehavior.AnimatedSource="flex.gif">
                            <Image.Clip>
                                <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                            </Image.Clip>
                        </Image>
                    </Grid>
                </Grid>
            </Grid>
            
            <!-- Компактный режим - иконка + текст + гифка -->
            <Grid x:Name="CompactMode" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Grid Grid.Column="0" Margin="5,0,0,0">
                    <Ellipse Width="50" Height="50" Fill="Gray"/>
                    <Image x:Name="AlbumArt" Width="40" Height="40" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5">
                        <Image.Clip>
                            <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                        </Image.Clip>
                        <Image.RenderTransform>
                            <RotateTransform x:Name="AlbumArtRotation" Angle="0"/>
                        </Image.RenderTransform>
                    </Image>
                </Grid>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock x:Name="CompactTitle" Text="Название" Foreground="White" FontSize="11" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="CompactArtist" Text="Исполнитель" Foreground="#AAAAAA" FontSize="9" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                
                <Grid Grid.Column="2" x:Name="GifCompactContainer" Visibility="Collapsed" Margin="0,0,5,0" Width="50" Height="50">
                    <Ellipse Width="50" Height="50" Fill="Gray"/>
                    <Image x:Name="GifCompact" Width="40" Height="40" Stretch="UniformToFill" gif:ImageBehavior.AnimatedSource="flex.gif">
                        <Image.Clip>
                            <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                        </Image.Clip>
                    </Image>
                </Grid>
            </Grid>
            
            <!-- Расширенный режим -->
            <Grid x:Name="ExpandedMode" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Grid Grid.Column="0" Margin="5,0,0,0">
                    <Ellipse Width="50" Height="50" Fill="Gray"/>
                    <Image x:Name="AlbumArtExpanded" Width="40" Height="40" Stretch="UniformToFill" RenderTransformOrigin="0.5,0.5">
                        <Image.Clip>
                            <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                        </Image.Clip>
                        <Image.RenderTransform>
                            <RotateTransform x:Name="AlbumArtExpandedRotation" Angle="0"/>
                        </Image.RenderTransform>
                    </Image>
                </Grid>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                    <TextBlock x:Name="TrackTitle" Text="Название трека" Foreground="White" FontSize="12" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ArtistName" Text="Исполнитель" Foreground="#AAAAAA" FontSize="10" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                
                <Grid Grid.Column="2" x:Name="GifExpandedContainer" Visibility="Collapsed" Margin="0,0,5,0" Width="50" Height="50">
                    <Ellipse Width="50" Height="50" Fill="Gray"/>
                    <Image x:Name="GifExpanded" Width="40" Height="40" Stretch="UniformToFill" gif:ImageBehavior.AnimatedSource="flex.gif">
                        <Image.Clip>
                            <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                        </Image.Clip>
                    </Image>
                </Grid>
                
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button x:Name="PrevButton" Content="⏮" Style="{StaticResource ControlButtonStyle}" Click="PrevButton_Click"/>
                    <Button x:Name="PlayPauseButton" Content="⏸" Style="{StaticResource ControlButtonStyle}" Click="PlayPauseButton_Click"/>
                    <Button x:Name="NextButton" Content="⏭" Style="{StaticResource ControlButtonStyle}" Click="NextButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
        </Border>
    </Grid>
</Window>
