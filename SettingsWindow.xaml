<Window x:Class="DynamicIslandPC.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки" 
        Width="400" Height="320"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#2C2C2E">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0">
            <TextBlock Text="Позиция X:" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SliderX" Grid.Column="0" Minimum="0" Maximum="1920" Value="0" 
                        TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                <TextBox x:Name="TextX" Grid.Column="1" Text="0" Margin="10,0,0,0" 
                         VerticalContentAlignment="Center" TextAlignment="Center" 
                         Background="#3C3C3E" Foreground="White" BorderBrush="#555" 
                         TextChanged="TextX_TextChanged"/>
            </Grid>
        </StackPanel>
        
        <StackPanel Grid.Row="2">
            <TextBlock Text="Позиция Y:" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SliderY" Grid.Column="0" Minimum="0" Maximum="1080" Value="0" 
                        TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                <TextBox x:Name="TextY" Grid.Column="1" Text="0" Margin="10,0,0,0" 
                         VerticalContentAlignment="Center" TextAlignment="Center" 
                         Background="#3C3C3E" Foreground="White" BorderBrush="#555" 
                         TextChanged="TextY_TextChanged"/>
            </Grid>
        </StackPanel>
        
        <StackPanel Grid.Row="4">
            <TextBlock Text="Цвет фона:" Foreground="White" FontSize="14" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Вверху" Width="80" Height="30" Margin="0,0,10,0" Click="TopButton_Click"
                            Background="#3C3C3E" Foreground="White" BorderBrush="#555"/>
                    <Button Content="Внизу" Width="80" Height="30" Click="BottomButton_Click"
                            Background="#3C3C3E" Foreground="White" BorderBrush="#555"/>
                </StackPanel>
                <Button x:Name="ColorButton" Grid.Column="1" Content="Выбрать" Height="30" Click="ColorButton_Click"
                        Background="#3C3C3E" Foreground="White" BorderBrush="#555"/>
            </Grid>
        </StackPanel>
        
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Закрыть" Width="100" Height="35" Click="CancelButton_Click"
                    Background="#9B59B6" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
