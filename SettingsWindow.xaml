<Window x:Class="DynamicIslandPC.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Width="520" Height="660"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#202024">

    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8A8B2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#3A3A40"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555560"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource SettingsButton}">
            <Setter Property="Background" Value="#9B59B6"/>
            <Setter Property="BorderBrush" Value="#9B59B6"/>
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="ColorPresetButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Настройки island" Foreground="White" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Позиция, тема и кастомный декор рядом с плеером." Foreground="#A8A8B2" FontSize="11" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,18,0,18" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="#2B2B31" BorderBrush="#3D3D46" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Позиция" Style="{StaticResource SectionTitle}"/>

                        <TextBlock Text="Центр по горизонтали (X):" Foreground="White" FontSize="13" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="68"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SliderX" Grid.Column="0" Minimum="0" Maximum="1920" Value="0"
                                    TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <TextBox x:Name="TextX" Grid.Column="1" Text="0" Margin="12,0,0,0"
                                     VerticalContentAlignment="Center" TextAlignment="Center"
                                     Background="#38383E" Foreground="White" BorderBrush="#555560"
                                     TextChanged="TextX_TextChanged"/>
                        </Grid>

                        <TextBlock Text="Позиция Y:" Foreground="White" FontSize="13" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="68"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SliderY" Grid.Column="0" Minimum="0" Maximum="1080" Value="0"
                                    TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>
                            <TextBox x:Name="TextY" Grid.Column="1" Text="0" Margin="12,0,0,0"
                                     VerticalContentAlignment="Center" TextAlignment="Center"
                                     Background="#38383E" Foreground="White" BorderBrush="#555560"
                                     TextChanged="TextY_TextChanged"/>
                        </Grid>

                        <TextBlock Text="Быстрая позиция:" Foreground="White" FontSize="13" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Вверху" Style="{StaticResource SettingsButton}" Click="TopButton_Click"/>
                            <Button Grid.Column="2" Content="Внизу" Style="{StaticResource SettingsButton}" Click="BottomButton_Click"/>
                            <Button Grid.Column="4" Content="По центру" Style="{StaticResource SettingsButton}" Click="CenterButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="#2B2B31" BorderBrush="#3D3D46" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Тема" Style="{StaticResource SectionTitle}"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="DarkThemeButton" Grid.Column="0" Content="Тёмная" Style="{StaticResource SettingsButton}" Click="DarkThemeButton_Click"/>
                            <Button x:Name="LightThemeButton" Grid.Column="2" Content="Светлая" Style="{StaticResource SettingsButton}" Click="LightThemeButton_Click"/>
                        </Grid>

                        <TextBlock Text="Цвет фона:" Foreground="White" FontSize="13" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="BackgroundColorPreview" Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#FF000000" BorderBrush="#555560" BorderThickness="1"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <WrapPanel Margin="0,0,0,8">
                                    <Button Style="{StaticResource ColorPresetButton}" Background="#FF000000" Tag="#FF000000" Click="ColorPresetButton_Click"/>
                                    <Button Style="{StaticResource ColorPresetButton}" Background="#FFFFFFFF" Tag="#FFFFFFFF" Click="ColorPresetButton_Click"/>
                                    <Button Style="{StaticResource ColorPresetButton}" Background="#FF181820" Tag="#FF181820" Click="ColorPresetButton_Click"/>
                                    <Button Style="{StaticResource ColorPresetButton}" Background="#FF241935" Tag="#FF241935" Click="ColorPresetButton_Click"/>
                                    <Button Style="{StaticResource ColorPresetButton}" Background="#FF102A33" Tag="#FF102A33" Click="ColorPresetButton_Click"/>
                                    <Button Style="{StaticResource ColorPresetButton}" Background="#FF352010" Tag="#FF352010" Click="ColorPresetButton_Click"/>
                                    <Button Style="{StaticResource ColorPresetButton}" Background="#FF13351F" Tag="#FF13351F" Click="ColorPresetButton_Click"/>
                                    <Button Style="{StaticResource ColorPresetButton}" Background="#FF32191D" Tag="#FF32191D" Click="ColorPresetButton_Click"/>
                                </WrapPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="HEX" Foreground="#A8A8B2" FontSize="11" VerticalAlignment="Center"/>
                                    <TextBox x:Name="BackgroundHexText" Grid.Column="2" Height="28" Text="#FF000000"
                                             VerticalContentAlignment="Center" CharacterCasing="Upper"
                                             Background="#38383E" Foreground="White" BorderBrush="#555560"
                                             TextChanged="BackgroundHexText_TextChanged"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="R" Foreground="#FF7A7A" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Slider x:Name="RedSlider" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="RgbSlider_ValueChanged"/>
                            <TextBlock x:Name="RedValueText" Grid.Column="2" Text="0" Foreground="#D8D8E0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="G" Foreground="#70E084" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Slider x:Name="GreenSlider" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="RgbSlider_ValueChanged"/>
                            <TextBlock x:Name="GreenValueText" Grid.Column="2" Text="0" Foreground="#D8D8E0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="42"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="B" Foreground="#74A7FF" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Slider x:Name="BlueSlider" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="RgbSlider_ValueChanged"/>
                            <TextBlock x:Name="BlueValueText" Grid.Column="2" Text="0" Foreground="#D8D8E0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Прозрачность фона:" Foreground="White" FontSize="13"/>
                            <TextBlock x:Name="BackgroundOpacityText" Grid.Column="1" Text="70%" Foreground="#D8D8E0" FontSize="13" FontWeight="SemiBold"/>
                        </Grid>
                        <Slider x:Name="BackgroundOpacitySlider" Minimum="10" Maximum="100" Value="70"
                                TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="BackgroundOpacitySlider_ValueChanged"/>

                        <CheckBox x:Name="AdaptiveAlbumThemeCheckBox"
                                  Content="Адаптивный фон от обложки"
                                  Foreground="White"
                                  Margin="0,14,0,0"
                                  Checked="AdaptiveAlbumThemeChanged"
                                  Unchecked="AdaptiveAlbumThemeChanged"/>
                    </StackPanel>
                </Border>

                <Border Background="#2B2B31" BorderBrush="#3D3D46" BorderThickness="1" CornerRadius="16" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Декор рядом" Style="{StaticResource SectionTitle}"/>
                        <CheckBox x:Name="DecorationEnabledCheckBox"
                                  Content="Показывать декор рядом с island"
                                  Foreground="White"
                                  Margin="0,0,0,10"
                                  Checked="DecorationEnabledChanged"
                                  Unchecked="DecorationEnabledChanged"/>

                        <TextBlock Text="Можно выбрать PNG/JPG/BMP, GIF или видео MP4/WMV/AVI/MOV/WebM. Если файл не выбран, используется стандартный flex.gif." Style="{StaticResource HintText}" Margin="0,0,0,12"/>

                        <TextBlock Text="Файл декора:" Foreground="White" FontSize="13" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DecorationPathText" Grid.Column="0" IsReadOnly="True" Text="flex.gif"
                                     Height="32" VerticalContentAlignment="Center"
                                     Background="#38383E" Foreground="#D8D8E0" BorderBrush="#555560"/>
                            <Button Grid.Column="2" Content="Выбрать" Style="{StaticResource SettingsButton}" Click="DecorationChooseButton_Click"/>
                            <Button Grid.Column="4" Content="Сбросить" Style="{StaticResource SettingsButton}" Click="DecorationResetButton_Click"/>
                        </Grid>

                        <TextBlock x:Name="DecorationInfoText" Text="Сейчас используется стандартный flex.gif." Style="{StaticResource HintText}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <Button Content="Назад" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Click="CancelButton_Click"/>
        </Grid>
    </Grid>
</Window>
