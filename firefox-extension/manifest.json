{
  "manifest_version": 2,
  "name": "Yandex Music Bridge",
  "version": "1.0",
  "description": "Отправляет информацию о треке в Dynamic Island PC",
  "permissions": [
    "<all_urls>",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
