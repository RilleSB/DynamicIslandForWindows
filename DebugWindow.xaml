<Window x:Class="DynamicIslandPC.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug Info" Height="400" Width="600">
    <Grid>
        <TextBox x:Name="DebugText" 
                 TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="10"/>
    </Grid>
</Window>